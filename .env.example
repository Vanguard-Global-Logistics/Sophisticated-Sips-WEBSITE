# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server only, never exposed

# ===== Owner =====
OWNER_EMAIL=sophisticatedsnacksfl@gmail.com             # the ONLY email allowed into /owner

# ===== AI (server-side only) =====
ANTHROPIC_API_KEY=sk-ant-...

# ===== Email (Resend) =====
RESEND_API_KEY=re_...
OUTREACH_FROM="Amy at Sophisticated Sips <sophisticatedsnacksfl@gmail.com
>"

# ===== Square =====
SQUARE_ACCESS_TOKEN=EAAA...                        # server only
SQUARE_LOCATION_ID=L...
SQUARE_ENVIRONMENT=sandbox                         # sandbox | production
SQUARE_WEBHOOK_SIGNATURE_KEY=...                   # from the webhook subscription
NEXT_PUBLIC_SITE_URL=https://sophisticatedsips.com

# ===== Environment mode =====
# "staging" shows the staging banner, blocks real Square charges, redirects all
# outbound email to OWNER_EMAIL, and de-indexes the site. Set "production" ONLY
# on the live site's Production environment variables in Vercel.
NEXT_PUBLIC_APP_ENV=staging

# ===== Security =====
UNSUBSCRIBE_SECRET=any-long-random-string
CRON_SECRET=any-long-random-string

# ===== Business info =====
BUSINESS_ADDRESS="Sophisticated Sips, 12371 Lacey Dr, New Port Richey, FL 34654"  # required in outreach footers (CAN-SPAM)
BUSINESS_LAT=27.9506        # for the dashboard weather card (Open-Meteo, no key needed)
BUSINESS_LON=-82.4572

